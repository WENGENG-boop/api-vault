# Normalize line endings: text files are stored and checked out with LF,
# regardless of core.autocrlf. Prevents LF/CRLF churn across Windows/macOS/Linux.
* text=auto eol=lf

# Source / config / docs — explicit LF
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.cjs   text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.svg   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Windows launchers must keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary assets — never touch
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.pdf   binary
