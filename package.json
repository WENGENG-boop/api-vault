{
  "name": "api-vault-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Local browser API key vault, proxy, and real billing sync demo.",
  "main": "dist-main/server/server.js",
  "scripts": {
    "dev": "npm run build && node dist-main/server/server.js",
    "dev:renderer": "vite --host 127.0.0.1",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "serve": "node dist-main/server/server.js",
    "start": "npm run build && node dist-main/server/server.js",
    "test": "npm run build:main && node --test tests/*.test.cjs"
  },
  "dependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "typescript": "6.0.3",
    "vite": "8.0.11"
  }
}
